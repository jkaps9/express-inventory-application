<html>
  <head>
    <%- include("partials/head.ejs") %>
  </head>
  <body>
    <%- include("./partials/header.ejs") %>
    <main>
      <section>
        <div class="container">
          <%- include("partials/errors.ejs") %>
          <form method="POST" action="/item/update/?id=<%= item.id %>" class="input-form">
            <header>
              <h2>Update Item</h2>
            </header>
            <main>
              <section>
                  <div class="input-group">
                      <label for="category">Category</label>
                      <select name="category" id="category">
                          <% categories.forEach((category)=>{%>
                              <option value="<%= category.name %>" <%= category.name === item.category_name ? 'selected' : '' %>><%= category.name %></option>
                          <% }) %>
                      </select>
                  </div>
                <div class="input-group">
                  <label for="name">Name</label>
                  <input type="text" id="name" name="name" placeholder="Item Name" value="<%= item.name %>"/>
                </div>
                <div class="input-group">
                  <label for="price">Price</label>
                  <input type="number" step="0.01" id="price" name="price"  value="<%= item.price %>"/>
                </div>
                <div class="input-group">
                  <label for="description">Description</label>
                  <textarea
                    name="description"
                    id="description"
                    placeholder="Describe the item..."
                  ><%= item.description %></textarea>
                </div>
                <button type="submit" class="btn">Submit</button>
              </section>
            </main>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
