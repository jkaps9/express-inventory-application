<html>
  <head>
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %></title>
    <style>
        body {
            line-height: 1.6;
        }
        
        ul {
            list-style-type: none;
        }

        .category-list__item {
            font-weight: 700;
        }
    </style>
  </head>
  <body>
    <h1><%= title %></h1>
    <ul class="category-list">
        <% categories.forEach((category) => { %>
            <li class="category-list__item">
                <%= category.name %>
            </li>
        <% }) %>
    </ul>
  </body>
</html>
