<html>
  <head>
    <%- include("../partials/head.ejs") %>
  </head>
  <body>
    <main>
      <section>
        <div class="container">
          <a href="/">Go Home</a>
          <div class="row">
            <form action="/item/update/<%= item.id %>" method="GET" style="display:block;">
                <button type="submit" style="background-color: blue; color: white; border: 1px solid black; padding: 0.5em 0.75em;">Update Item</button>
            </form>
            <form action="/item/delete/?id=<%= item.id %>" method="POST" style="display:block;">
                <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');" style="background-color: red; color: white; border: 1px solid black; padding: 0.5em 0.75em;">Delete Item</button>
            </form>
          </div>
            <%- include("./item.ejs", {item: item}) %>
        </div>
      </section>
    </main>
  </body>
  </html>   